# Copy this file to .env and fill in real values

# MongoDB connection string
MONGO_URI=

# Server port
PORT=5000

# JWT secret for signing tokens
JWT_SECRET=

# ImageKit credentials (for image uploads)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Optional: Government market API key if used
GOVT_MARKET_API_KEY=

# Resend API key for sending emails (https://resend.com)
RESEND_API_KEY=

# Optional: Custom sender email (Resend free tier uses onboarding@resend.dev)
FROM_EMAIL=CropPlan <onboarding@resend.dev>

# Admin email to receive farmer registration notifications
ADMIN_EMAIL=

# FRONTEND URL(s) for CORS
FRONTEND_URL=http://localhost:5173

# NODE_ENV=development | production
NODE_ENV=development
