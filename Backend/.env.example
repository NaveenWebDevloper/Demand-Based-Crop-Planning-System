# Copy this file to .env and fill in real values

# MongoDB connection string
MONGO_URI=

# Server port
PORT=5000

# JWT secret for signing tokens
JWT_SECRET=

# ImageKit credentials (for image uploads)
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Optional: Government market API key if used
GOVT_MARKET_API_KEY=

# SMTP configuration for sending emails (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional: SendGrid API (preferred on constrained hosts)
SENDGRID_API_KEY=
SENDGRID_SENDER=your-sender@example.com

# FRONTEND URL(s) for CORS
FRONTEND_URL=http://localhost:5173

# NODE_ENV=development | production
NODE_ENV=development
